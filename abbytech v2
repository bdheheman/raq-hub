-- Slider (Exact from your script)
local isSliding = false
local function updateSlider()
    local mousePos = UserInputService:GetMouseLocation().X
    local trackPos = Track.AbsolutePosition.X
    local trackSize = Track.AbsoluteSize.X
    local relativePos = math.clamp((mousePos - trackPos) / trackSize, 0, 1)

    Knob.Position = UDim2.new(relativePos, -6, 0.5, -6)
    Percentage.Text = math.floor(relativePos * 100) .. "%"
    currentTransparency = relativePos
    config.transparencyValue = currentTransparency
    saveConfig()
end

Knob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isSliding = true
        updateSlider()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isSliding = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isSliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateSlider()
    end
end)

-- Ghost ESP Logic
local function createGhostGui()
    if not flashESPEnabled or billboard then return end
    attachmentPart = ghostModel and (ghostModel.PrimaryPart or ghostModel:FindFirstChild("HumanoidRootPart") or ghostModel:FindFirstChildWhichIsA("BasePart"))
    if not attachmentPart then return end

    billboard = Instance.new("BillboardGui")
    billboard.Name = "GhostDistanceGui"
    billboard.Adornee = attachmentPart
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 200, 0, 60)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.Parent = attachmentPart

    local nameLabel = Instance.new("TextLabel", billboard)
    nameLabel.Size = UDim2.new(1,0,0.5,0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = "Flash Helper"
    nameLabel.TextColor3 = Color3.new(0,0,0)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.new(1,1,1)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 18

    local distLabel = Instance.new("TextLabel", billboard)
    distLabel.Size = UDim2.new(1,0,0.5,0)
    distLabel.Position = UDim2.new(0,0,0.5,0)
    distLabel.BackgroundTransparency = 1
    distLabel.Text = "0 studs"
    distLabel.TextColor3 = Color3.new(1,1,1)
    distLabel.Font = Enum.Font.GothamBold
    distLabel.TextSize = 16

    RunService.RenderStepped:Connect(function()
        if not flashESPEnabled or not ghostModel or not ghostModel.Parent then
            if billboard then billboard.Enabled = false end
            return
        end
        local rp = attachmentPart.Position
        local pp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if pp then
            local d = math.floor((rp - pp.Position).Magnitude)
            distLabel.Text = d .. ((d >= 8 and d <= 26) and " studs - GOOD FLASH TP" or " studs - BAD")
            distLabel.TextColor3 = (d >= 8 and d <= 26) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,50,50)
        end
    end)
end

ghostModel = workspace:FindFirstChild("Ghost")
if ghostModel and flashESPEnabled then
    createGhostGui()
end

workspace.ChildAdded:Connect(function(c)
    if c.Name == "Ghost" then
        ghostModel = c
        if flashESPEnabled then
            createGhostGui()
        end
    end
end)
workspace.ChildRemoved:Connect(function(c)
    if c.Name == "Ghost" then
        ghostModel = nil
        if billboard then billboard:Destroy() billboard = nil end
    end
end)

-- Full Align Camera Logic (from original)
local podiumAlignCooldown = false

local function podiumAlign()
    if podiumAlignCooldown then return end
    podiumAlignCooldown = true

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then 
        podiumAlignCooldown = false 
        return 
    end

    local myPos = root.Position
    local nearestPart, nearestDist = nil, math.huge
    local plots = workspace:FindFirstChild("Plots")

    if plots then
        for _, plot in ipairs(plots:GetChildren()) do
            for _, obj in ipairs(plot:GetDescendants()) do
                if obj.Name == "AnimalPodiums" then
                    for i = 1, 30 do
                        local podium = obj:FindFirstChild(tostring(i))
                        if podium then
                            local base = podium:FindFirstChild("Base")
                            local spawn = base and base:FindFirstChild("Spawn")
                            if spawn then
                                local dist = (myPos - spawn.Position).Magnitude
                                if dist < nearestDist then
                                    nearestPart = spawn
                                    nearestDist = dist
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    if nearestPart then
        local targetPos = nearestPart.Position + Vector3.new(0, nearestPart.Size.Y/2 + 4, 0)
        root.CFrame = CFrame.new(targetPos) * root.CFrame.Rotation
        
        local camPos = targetPos + Vector3.new(-10, -40, 0) + (root.CFrame.LookVector * -28)
        local lookAt = targetPos + (root.CFrame.LookVector * 50)
        Camera.CFrame = CFrame.lookAt(camPos, lookAt)
    end

    task.wait(1.2)
    podiumAlignCooldown = false
end

AlignBtn.MouseButton1Click:Connect(podiumAlign)
