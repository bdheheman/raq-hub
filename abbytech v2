-- Transparency System
local CONFIG_FILE = "TransparencyConfig.json"
local defaultConfig = { transparencyEnabled = false, transparencyValue = 1.0 }
local config = {}
local brainrotEnabled = false
local currentTransparency = 1.0
local trackedParts = {}
local brainrotNames = {}

local function loadConfig()
    local success, data = pcall(function() return HttpService:JSONDecode(readfile(CONFIG_FILE)) end)
    config = success and data or defaultConfig
end
local function saveConfig()
    pcall(function() writefile(CONFIG_FILE, HttpService:JSONEncode(config)) end)
end
loadConfig()

brainrotEnabled = config.transparencyEnabled or false
currentTransparency = config.transparencyValue or 1.0

-- Load brainrot names
local modelsFolder = ReplicatedStorage:FindFirstChild("Models")
if modelsFolder then
    local animals = modelsFolder:FindFirstChild("Animals")
    if animals then
        for _, v in pairs(animals:GetChildren()) do brainrotNames[v.Name] = true end
    end
end

local function checkAndTrack(obj)
    if obj:IsA("BasePart") or obj:IsA("Decal") then
        local p = obj.Parent
        while p and p ~= workspace do
            if brainrotNames[p.Name] then trackedParts[obj] = true break end
            p = p.Parent
        end
    end
end

for _, obj in pairs(workspace:GetDescendants()) do checkAndTrack(obj) end
workspace.DescendantAdded:Connect(checkAndTrack)

RunService.RenderStepped:Connect(function()
    for obj in pairs(trackedParts) do
        if obj and obj.Parent then
            obj.LocalTransparencyModifier = brainrotEnabled and currentTransparency or 0
        else trackedParts[obj] = nil end
    end
end)

